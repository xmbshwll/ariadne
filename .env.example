# Ariadne runtime configuration
# Copy to .env and fill in the values you need.

# Spotify official Web API credentials.
# When both are set, Spotify target search is enabled and authenticated validation can run.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Default Apple Music storefront for lookup/search when not implied by the URL.
# Examples: us, gb, de, jp
APPLE_MUSIC_STOREFRONT=us

# Apple Music official API credentials for generating a MusicKit developer token.
# Create a MusicKit private key in Apple Developer, then point this path at the downloaded .p8 file.
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_PRIVATE_KEY_PATH=

# TIDAL developer credentials for future validation/adapter work.
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# Per-request timeout for Ariadne's default HTTP client.
# Uses Go duration syntax such as 15s, 30s, or 1m.
ARIADNE_HTTP_TIMEOUT=15s

# CLI diagnostics log level.
# Supported values: error, warn, info, debug.
# Warning: debug logging prints effective config values, including secrets.
# ARIADNE_LOG_LEVEL=error
